# Discord Bot
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_guild_id_here

# Hub Channel — Hub embed + buttons (Open / Target / Practice PvE / My Stats)
# Legacy alias: SHADOW_DUEL_HUB_CHANNEL (same value) if you still use the old name
SHADOW_DUEL_HUB_CHANNEL_ID=your_hub_channel_id_here

# Challenge cards (invites) are posted here
SHADOW_DUEL_CHALLENGE_CHANNEL_ID=your_challenge_channel_id_here

# Public match history feed (who vs who)
SHADOW_DUEL_HISTORY_CHANNEL_ID=your_history_channel_id_here

# Admin control channel (export/reset/cancel Shadow Duel)
SHADOW_DUEL_ADMIN_CHANNEL_ID=your_admin_channel_id_here

# Dedicated info channels (one persistent message each)
SHADOW_DUEL_LEADERBOARD_CHANNEL_ID=your_leaderboard_channel_id_here
SHADOW_DUEL_GUIDEBOOK_CHANNEL_ID=your_guidebook_channel_id_here

# Support Forums channels
SHADOW_DUEL_FORUMS_CHANNEL_ID=your_suggestion_forum_channel_id_here

# Optional: role ID that can view temp duel channels (admins). If not set, only the two players can view.
# BOBOZAN_ADMIN_ROLE_ID=

# MongoDB — required for Challenge Card IDs (001, 002, …), duel logs, and ladder
MONGO_URI=mongodb://127.0.0.1:27019/honorbot

# Prefix for temp duel text channels (category still uses "Shadow Duel - 001")
# Results in e.g. sd001-combat-log, sd001-poon1234
# BOBOZAN_DUEL_CHANNEL_PREFIX=sd

# Honor Points API
HONOR_POINTS_API_URL=http://localhost:3010
HONOR_POINTS_API_KEY=your_api_key_here

# Test mode: set to true to skip sending honor to central system (no points added/deducted)
# SHADOW_DUEL_SKIP_HONOR_POINTS=true

# Optional: Action logger
BOTS_LOGGER_URL=
BOTS_LOGGER_API_KEY=

# Game settings
ROUND_TIMEOUT_SECONDS=20
# Challenge card expiry (seconds). Open/Target challenge can be accepted within this time (default 180)
# BOBOZAN_CHALLENGE_EXPIRE_SECONDS=180
# When both players fail to choose in time, extra seconds before declaring draw (default 60)
# ROUND_TIMEOUT_BOTH_IDLE_SECONDS=60
# Delay in ms before deleting temp duel channels after match end (default 5000)
# SHADOW_DUEL_TEMP_CHANNEL_DELETE_DELAY_MS=5000
