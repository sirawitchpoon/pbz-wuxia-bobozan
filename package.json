{
  "name": "wuxia-bobozan",
  "version": "1.0.0",
  "description": "Wuxia BoboZan — round-based combat Discord bot integrated with Honor Points ecosystem",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "watch": "tsc --watch",
    "deploy": "ts-node src/deploy-commands.ts",
    "deploy:prod": "node dist/deploy-commands.js",
    "clear-commands": "ts-node src/clear-commands.ts",
    "reset-data": "ts-node scripts/reset-competition-data.ts",
    "purge-history-channel": "ts-node scripts/purge-match-history-channel.ts"
  },
  "keywords": ["discord", "bot", "wuxia", "combat", "honor-points"],
  "license": "ISC",
  "dependencies": {
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
